# GPT Rank Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Application will not start without these
# ============================================

# Database connection string (PostgreSQL)
# Example: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=

# Session secret for encrypting session cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ============================================
# REQUIRED for Stripe billing features
# ============================================

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (get from webhook settings in Stripe dashboard)
# Used to verify webhook signatures for security
STRIPE_WEBHOOK_SECRET=

# ============================================
# REQUIRED for AI prompt execution
# ============================================

# OpenAI API key (get from https://platform.openai.com/api-keys)
# Required if using OpenAI provider
OPENAI_API_KEY=

# Anthropic API key (get from https://console.anthropic.com/settings/keys)
# Optional - only required if using Claude models
# ANTHROPIC_API_KEY=

# Perplexity API key (get from https://www.perplexity.ai/settings/api)
# Optional - only required if using Perplexity models
# PERPLEXITY_API_KEY=

# Google AI API key (get from https://makersuite.google.com/app/apikey)
# Optional - only required if using Gemini models
# GOOGLE_AI_API_KEY=

# ============================================
# OPTIONAL - Application defaults
# ============================================

# Node environment (development, production, test)
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# Frontend URL for CORS (required in production if frontend is on different domain)
# Example: https://your-app.vercel.app
# FRONTEND_URL=

# ============================================
# OPTIONAL - Feature flags
# ============================================

# Enable debug logging (default: false)
# DEBUG=true

# ============================================
# Migration Notes
# ============================================
# This application has been migrated from Replit to standard deployment.
# The following Replit-specific variables are NO LONGER NEEDED:
# - REPLIT_CONNECTORS_HOSTNAME
# - REPL_IDENTITY
# - WEB_REPL_RENEWAL
# - REPLIT_DOMAINS
# - REPLIT_DEPLOYMENT
# - AI_INTEGRATIONS_OPENAI_*
